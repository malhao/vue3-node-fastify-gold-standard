generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id        String    @id @default(uuid())
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Keyset pagination orders and filters on (createdAt, id); this composite index
  // lets Postgres serve each page from an index range instead of sorting the table.
  @@index([createdAt, id])
  @@map("tasks")
}
