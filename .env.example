# Copy to .env and fill in real values. Never commit the real .env.

# --- apps/api ---
NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gold_standard?schema=public"
CORS_ORIGIN="http://localhost:5173"
# Static bearer token the API accepts (stub auth). Must match VITE_API_TOKEN below.
API_AUTH_TOKEN="dev-local-token"

# OpenTelemetry (vendor deferred; point at a local Collector)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="api"

# --- apps/web ---
# Only VITE_-prefixed vars reach the browser bundle. Never put secrets here.
# Origin only — the generated API client's paths already include the versioned prefix (/api/v1/...).
VITE_API_ORIGIN="http://localhost:3000"
# Dev bearer token sent with API requests (stub auth). Must match API_AUTH_TOKEN above.
VITE_API_TOKEN="dev-local-token"
VITE_OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
