# Copy to .env and fill in real values. Never commit the real .env.

# --- apps/api ---
NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gold_standard?schema=public"
CORS_ORIGIN="http://localhost:5173"

# OpenTelemetry (vendor deferred; point at a local Collector)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="api"

# --- apps/web ---
# Only VITE_-prefixed vars reach the browser bundle. Never put secrets here.
VITE_API_BASE_URL="http://localhost:3000/api/v1"
